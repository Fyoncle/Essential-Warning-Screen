{
  "schemaVersion": 1,
  "id": "essentialwarningscreen",
  "version": "${version}",
  "name": "Essential Warning Screen",
  "description": "This mod adds a warning screen if Essential is installed to keep your modpack users safe.",
  "authors": [
    "Fyoncle"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/essential-warning-screen",
    "sources": "https://github.com/Fyoncle/essential-warning-screen",
    "issues": "https://github.com/Fyoncle/essential-warning-screen/issues"
  },
  "license": "MIT",
  "icon": "assets/essentialwarningscreen/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "net.essentialwarningscreen.EssentialWarningScreen"
    ]
  },
  "mixins": [
    "essentialwarningscreen.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.10",
    "minecraft": "1.20.1",
    "fabric-api": "*",
    "fzzy_config": "*"
  },
  "fzzy_config": [
    "essentialwarningscreen"
  ]
}